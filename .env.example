# Rasaveda (रसवेद) — Environment Configuration
# Copy this file to .env and fill in your values
# No API keys required — runs fully locally via Ollama.

# Ollama model to use for generation
# After creating the custom model: ollama create rasaveda -f Modelfile
# Use "rasaveda" for the custom persona model (recommended)
# Fallback options: qwen2.5:7b, llama3.2:3b, mistral, gemma3:4b
OLLAMA_MODEL=rasaveda

# Ollama server URL (default for local; set to remote URL for cloud/VPS)
OLLAMA_BASE_URL=http://localhost:11434

# App settings (defaults shown)
CHROMA_PERSIST_DIR=./chroma_db
COLLECTION_NAME=rasaveda_recipes
TOP_K_RESULTS=8
RECIPES_PATH=./data/recipes.json
ADMIN_PASSWORD=rasaveda-admin
